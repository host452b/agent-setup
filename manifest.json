  "plugins": {
    "superpowers": {
      "targets": {
        "claude": {
          "method": "claude-plugin",
          "coverage": "native",
          "platforms": [
            "darwin",
            "linux",
            "wsl",
            "windows"
          ],
          "requires": [
            "claude",
            "jq"
          ],
          "install_scope": "user",
          "args": {
            "marketplace_src": "obra/superpowers-marketplace",
            "marketplace_name": "superpowers-marketplace",
            "plugin": "superpowers"
          },
          "safety": {
            "risk": "low",
            "network": true,
            "executes_remote_code": false,
            "requires_admin": false,
            "requires_confirmation": false
          },
          "checks": {
            "after": [
              {
                "type": "claude_plugin_installed",
                "name": "superpowers"
              }
            ]
          },
          "conflict_policy": "skip"
        },
        "codex": {
          "method": "codex-plugin",
          "coverage": "partial",
          "platforms": [
            "darwin",
            "linux",
            "wsl",
            "windows"
          ],
          "requires": [
            "codex"
          ],
          "install_scope": "user",
          "args": {
            "marketplace_src": "obra/superpowers",
            "plugin": "superpowers",
            "marketplace_name": "superpowers-dev"
          },
          "safety": {
            "risk": "medium",
            "network": true,
            "executes_remote_code": false,
            "requires_admin": false,
            "requires_confirmation": true
          },
          "conflict_policy": "skip"
        },
        "cursor": {
          "method": "manual",
          "coverage": "manual",
          "platforms": [
            "darwin",
            "linux",
            "wsl",
            "windows"
          ],
          "requires": [],
          "safety": {
            "risk": "low",
            "network": false,
            "executes_remote_code": false,
            "requires_admin": false,
            "requires_confirmation": false
          },
          "manual": {
            "reason": "Cursor installs superpowers via the in-chat /add-plugin marketplace; no CLI exists.",
            "steps": [
              "Open a Cursor Agent chat",
              "Run: /add-plugin superpowers"
            ],
            "verification": [
              "Ask Cursor to list installed plugins and confirm superpowers appears"
            ]
          }
        }
      }
    },
